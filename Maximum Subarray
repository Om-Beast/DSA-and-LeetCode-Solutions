class Solution {
public:
    int maxSubArray(vector<int>& nums) {
        long long sum=0, maxi=LONG_MIN;
        int st=-1;
        int en=-1;
        for(int i=0; i<nums.size(); ++i){
            if(sum==0)int start=i;
            sum+=nums[i];
            if(sum>maxi){
                maxi=sum;
                st=start;
                en=i;

            }
            if(sum<0)sum=0;
        }
        return maxi;
        
    }
};
