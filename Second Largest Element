class Solution {
public:
    int secondLargestElement(vector<int>& nums) {
        int mx1=-1;
        int mx2=-1;
        for(int i=0; i<nums.size(); ++i){
            if(nums[i]>mx1){
                mx2=mx1;
                mx1=nums[i];
            }
            else if(nums[i]>mx2 && mx1!=nums[i]){
                mx2=nums[i];
            }
        }
        return mx2;
        //your code goes here
      
    }
};
