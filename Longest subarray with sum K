class Solution{
public:
    int longestSubarray(vector<int> &nums, int k){
        int sm=0;
        map<int,int>m;
        int ln=0;
        for(int i=0; i<nums.size(); ++i){
            sm+=nums[i];

          if(sm==k){
            ln=max(ln,i+1);
          }
            int rem=sm-k;
            if(m.find(rem)!=m.end()){
                ln=max(ln,i-m[rem]);
            }
            m[sm]=i;
        }
        return ln;

        
    }
};
