class Solution {
public:
    long long maxSum(vector<int>& nums, int k, int mul) {
        long long ans=0;
        sort(nums.begin(),nums.end());
        for(int i=nums.size()-1; i>=0; --i){
            if(k==0)return ans;
            if(mul>0){
                ans+=mul*1LL*nums[i];
                mul--;
                k--;
            }
            else{
                ans+=nums[i];
                k--;
            }  
        }
        return ans;
        
    }
};
