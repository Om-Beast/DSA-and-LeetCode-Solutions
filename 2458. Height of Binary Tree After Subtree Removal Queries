
class Solution {
public:

int lvl[100001];
int height[100001];
int mxheight[100001];
int mnheight[100001];
 int dfs(TreeNode* root, int Level){
    if(root==NULL) return 0 ;
    lvl[root->val]=Level;
    int left=dfs(root->left,Level+1);
    int right=dfs(root->right,Level+1);
    height[root->val]=1+max(left,right);
    if(mxheight[Level]<height[root->val]){
        mnheight[Level]=mxheight[Level];
        mxheight[Level]=height[root->val];
    }
    else if(height[root->val]>mnheight[Level]){
        mnheight[Level]=height[root->val];
    }
    return max(left,right)+1;

  }
    vector<int> treeQueries(TreeNode* root, vector<int>& queries) {
        vector<int> ans;
        dfs(root,0);
        for(int i=0; i<queries.size(); ++i){
           int lv=lvl[queries[i]];
           int best;
           if(mxheight[lv]==height[queries[i]]){
            best=mnheight[lv];
           }
           else{
            best=mxheight[lv];
           }
           ans.push_back(lv+best-1);
        }
        return ans;
        
    }
};
